{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-pro",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0,
    "analysis_concurrency": 4,
    "enrichment_concurrency": 2,
    "languages": ["zh"]
  },
  "email": {
    "enabled": true,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "${HORIZON_EMAIL}",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "torvalds",
        "enabled": false
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": false
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "arXiv Multi-Agent Systems",
        "url": "https://rss.arxiv.org/rss/cs.MA",
        "enabled": true,
        "category": "agent-research"
      },
      {
        "name": "机器之心",
        "url": "https://www.jiqizhixin.com/rss",
        "enabled": true,
        "category": "ai-industry"
      },
      {
        "name": "量子位",
        "url": "https://www.qbitai.com/feed",
        "enabled": true,
        "category": "ai-industry"
      },
      {
        "name": "InfoQ 中国",
        "url": "https://www.infoq.cn/feed?token=${INFOQ_TOKEN}&utm_source=feed",
        "enabled": true,
        "category": "ai-tech"
      },
      {
        "name": "ServeTheHome",
        "url": "https://www.servethehome.com/feed/",
        "enabled": true,
        "category": "hardware"
      },
      {
        "name": "Tom's Hardware",
        "url": "https://www.tomshardware.com/feeds/all",
        "enabled": true,
        "category": "hardware"
      },
      {
        "name": "LWN.net (subscriber full-text)",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "singularity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        }
      ],
      "users": [
        {
          "username": "iamthatis",
          "enabled": true,
          "sort": "new",
          "fetch_limit": 10
        }
      ],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": true,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "equities",
          "symbols": ["AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA"]
        },
        {
          "name": "semiconductors",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "semiconductors",
          "symbols": ["AMD", "INTC", "ASML", "TSM", "MU", "AVGO", "QCOM", "AMAT", "LRCX", "ARM"]
        }
      ]
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 12
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
